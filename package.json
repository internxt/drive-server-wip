{
  "name": "drive-server-wip",
  "version": "0.0.1",
  "description": "",
  "author": "Internxt",
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "cross-env NODE_ENV=production nest start -e 'node -r newrelic'",
    "cleanup:retroactive": "ts-node -r tsconfig-paths/register src/modules/jobs/commands/retroactive-deleted-items-cleanup.command.ts",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "NODE_ENV=production node -r newrelic dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:cov": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules cross-env NODE_ENV=test jest --config ./test/jest-e2e.json --forceExit",
    "test:e2e:watch": "cross-env NODE_ENV=test jest --config ./test/jest-e2e.json --watchAll",
    "migrate": "cross-env NODE_ENV=development sequelize db:migrate",
    "migrate:undo": "cross-env NODE_ENV=development sequelize db:migrate:undo",
    "migrate:prod": "cross-env NODE_ENV=production sequelize db:migrate",
    "migrate:prod:undo": "cross-env NODE_ENV=production sequelize db:migrate:undo",
    "migrate:test": "cross-env NODE_ENV=test sequelize db:migrate",
    "migrate:test:undo": "cross-env NODE_ENV=test sequelize db:migrate:undo",
    "db:seed:test:all": "cross-env NODE_ENV=test sequelize db:seed:all",
    "db:seed:test:all:undo": "cross-env NODE_ENV=test sequelize db:seed:undo:all",
    "postinstall": "yarn run prepare-hooks",
    "prepare-hooks": "husky install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@dashlane/pqc-kem-kyber512-node": "^1.0.0",
    "@internxt/inxt-js": "2.3.1",
    "@internxt/lib": "^1.4.1",
    "@keyv/redis": "^5.1.6",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/passport-jwt": "^3.0.13",
    "agentkeepalive": "^4.6.0",
    "ajv": "^8.18.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.0",
    "cache-manager": "^6.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "crypto": "^1.0.1",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.19",
    "geoip-lite": "^1.4.8",
    "hash-wasm": "^4.12.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.0",
    "multer-s3": "^3.0.1",
    "nanoid": "3",
    "nestjs-pino": "^4.6.0",
    "newrelic": "^13.14.0",
    "node-device-detector": "2.2.5",
    "openpgp": "^5.11.3",
    "passport": "^0.7.0",
    "passport-http": "^0.3.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prettysize": "^2.0.0",
    "qrcode": "^1.5.4",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.2",
    "semver": "^7.7.4",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "speakeasy": "^2.0.0",
    "sql-formatter": "^13.1.0",
    "stripe": "14.4.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@golevelup/ts-jest": "^1.2.1",
    "@internxt/eslint-config-internxt": "^1.0.9",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@types/chance": "^1.1.7",
    "@types/crypto-js": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "9.0.2",
    "@types/multer": "^1.4.13",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^20.19.11",
    "@types/sequelize": "^6.12.0",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "aws-sdk-client-mock": "^4.1.0",
    "chance": "^1.1.13",
    "cross-env": "^7.0.3",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^8.0.3",
    "jest": "^30.2.0",
    "lint-staged": "^15.1.0",
    "prettier": "^3.8.1",
    "sequelize-cli": "^6.6.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "roots": [
      "src",
      "test"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "lint-staged": {
    "./src/**/*.{js,ts}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "resolutions": {
    "@isaacs/brace-expansion": "^5.0.1",
    "eslint/**/ajv": "^6.14.0",
    "@eslint/**/ajv": "^6.14.0",
    "fast-xml-parser": "^5.3.6",
    "lodash": "^4.17.23",
    "qs": "^6.14.2",
    "webpack": "^5.104.1"
  }
}
